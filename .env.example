# Copy to .env and fill in real values. .env is gitignored — never commit it.

# ─── Required ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the auto_search qualifier (cheap classification).
# The CLI scorer (scorer.py) intentionally uses Opus for deep scoring —
# see the MODEL constant there.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Auto Search — warntracker connector (layoffs) ────────────────────
# No key needed (public site, scraped via Playwright). Optional overrides:
# WARN_USE_CACHE=true                # read cached rows instead of scraping
# WARN_CACHE_PATH=./data/warn_cache.json

# ─── Auto Search — leadership connector (SignalBase via Apify) ─────────
# Apify token from apify.com → Settings → Integrations. Billed ~1 credit
# per page (≤50 rows) of the SignalBase job-changes feed.
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: per-call qualifier trace location (debug; contains company data)
# QUALIFIER_TRACE_DIR=./data/qualifier_traces

# ─── Other API keys (future connectors / CLI scorer) ──────────────────
EXA_API_KEY=exa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRUNCHBASE_API_KEY=

# Postgres for the discovery store (unset → JSON-file repo). Railway gives this.
DATABASE_URL=postgresql://localhost/abm_discovery

# ─── API auth + serving (Discovery web app) ───────────────────────────
# HTTP Basic auth. BOTH must be set to enable the gate (unset → open, for
# localhost). Set both on Railway before exposing a public URL.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Comma-separated allowed origins for CORS (default "*"). Set to the UI origin
# only if you ever split the UI from the API.
# CORS_ORIGINS=*

# ─── Scoring budget + spend guardrails (see docs/SPEND_GUARDRAILS.md) ──
# Monthly budget the server enforces before any paid scoring op.
SCORING_MONTHLY_BUDGET=200
# Per-account spike cap: one account past this drops to error (normal ~$0.10).
SPEND_MAX_PER_ACCOUNT_USD=10
# Per-operation envelope: stop a batch when actual > estimate * ratio, or > hard cap.
SPEND_OP_OVERRUN_RATIO=1.4
# Estimate above this requires an explicit confirm_large_spend from the caller.
SPEND_MAX_OP_ESTIMATE_USD=150
SPEND_OP_HARD_CAP_USD=200
# Daily soft watch (warn in stats); 0 disables the optional hard daily cap.
SPEND_DAILY_WARN_USD=50
SPEND_DAILY_CAP_USD=0
# Estimated $/company for discovery qualify cost + the cron pre-flight estimate.
DISCOVERY_EST_QUAL_COST=0.12
# Monthly cap (USD) on discovery QUALIFY spend. The panel-1 meter reads against
# this and the manual "Run" is refused once month-to-date discovery spend hits it.
DISCOVERY_MONTHLY_BUDGET=50

# ─── Discovery cron knobs (used with --no-limit) ──────────────────────
# DISCOVERY_SIGNALBASE_MAX_PAGES=50
# DISCOVERY_SIGNALBASE_PER_PAGE=100
# DISCOVERY_JOBS_MAX_ROWS=200
# Restrict the jobs source to specific RCM titles (comma list; matches role
# bucket or query text). Fewer titles = fewer Apify rows + fewer qualifications.
# Great for controlled cost tests. Unset = all essential titles.
# DISCOVERY_JOBS_TITLES=revenue cycle,medical coder,medical biller
# SCORING_QA_CSV=1                   # set 0 to skip QA on CSV imports (cost)
