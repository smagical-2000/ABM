# Copy to .env and fill in real values. .env is gitignored — never commit it.

# ─── Required ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the auto_search qualifier (cheap classification).
# The CLI scorer (scorer.py) intentionally uses Opus for deep scoring —
# see the MODEL constant there.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Auto Search — warntracker connector (layoffs) ────────────────────
# No key needed (public site, scraped via Playwright). Optional overrides:
# WARN_USE_CACHE=true                # read cached rows instead of scraping
# WARN_CACHE_PATH=./data/warn_cache.json

# ─── Auto Search — leadership connector (SignalBase via Apify) ─────────
# Apify token from apify.com → Settings → Integrations. Billed ~1 credit
# per page (≤50 rows) of the SignalBase job-changes feed.
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: per-call qualifier trace location (debug; contains company data)
# QUALIFIER_TRACE_DIR=./data/qualifier_traces

# ─── Other API keys (future connectors / CLI scorer) ──────────────────
EXA_API_KEY=exa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRUNCHBASE_API_KEY=

# Postgres for the discovery store (unset → JSON-file repo). Railway gives this.
DATABASE_URL=postgresql://localhost/abm_discovery

# ─── API auth + serving (Discovery web app) ───────────────────────────
# HTTP Basic auth. BOTH must be set to enable the gate (unset → open, for
# localhost). Set both on Railway before exposing a public URL.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Comma-separated allowed origins for CORS (default "*"). Set to the UI origin
# only if you ever split the UI from the API.
# CORS_ORIGINS=*
