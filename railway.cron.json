{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.cron"
  },
  "deploy": {
    "startCommand": "python scripts/run_discovery.py --days 1 --no-limit",
    "cronSchedule": "0 14 * * 1-5",
    "healthcheckPath": null,
    "restartPolicyType": "NEVER"
  }
}
