{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.cron"
  },
  "deploy": {
    "startCommand": "python scripts/run_social.py --since-hours 24 --max-enrich 100",
    "cronSchedule": "0 13 * * 1-5",
    "healthcheckPath": null,
    "restartPolicyType": "NEVER"
  }
}
